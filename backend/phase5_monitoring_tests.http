############################################################
# === LECTURER ACTIONS (Use @lecturerToken for all) ===
############################################################

############################################################
# 3) Get Active Sessions
# Endpoint: GET /api/monitoring/sessions
# Auth: Lecturer token
# Expected: 200 OK
# Expected payload: Array of ExamSession rows with status='in_progress'
# Includes: tab_switch_count, fullscreen_exit_count, student username/email,
#           and exam_title (via joins)
############################################################
GET {{baseUrl}}/api/monitoring/sessions
Authorization: Bearer {{lecturerToken}}

# > {%
#   client.test("Get Active Sessions returns 200", function () {
#     client.assert(response.status === 200, "Expected HTTP 200");
#   });
# %}

###

############################################################
# 4) Get Alerts
# Endpoint: GET /api/monitoring/alerts
# Auth: Lecturer token
# Expected: 200 OK
# Expected payload: Array of unreviewed FlaggedActivity rows
#
# CRITICAL SCRIPT BEHAVIOR:
# - Extract the FIRST alert's flag_id from response.body[0].flag_id.
# - Save into global variable `alertId`.
# - Guard with `if (response.body.length > 0)` to prevent runtime errors
#   when there are currently no alerts.
############################################################
GET {{baseUrl}}/api/monitoring/alerts
Authorization: Bearer {{lecturerToken}}

# > {%
#   client.test("Get Alerts returns 200", function () {
#     client.assert(response.status === 200, "Expected HTTP 200");
#   });

#   // Defensive extraction to avoid crashes when alert list is empty.
#   if (Array.isArray(response.body) && response.body.length > 0) {
#     client.global.set("alertId", response.body[0].flag_id);
#   }
# %}

###

############################################################
# 5) Get Audit Logs (No Filters)
# Endpoint: GET /api/monitoring/audit-logs
# Auth: Lecturer token
# Expected: 200 OK
# Expected payload: Up to 100 most recent activity logs (default limit)
############################################################
GET {{baseUrl}}/api/monitoring/audit-logs
Authorization: Bearer {{lecturerToken}}

# > {%
#   client.test("Get Audit Logs (default) returns 200", function () {
#     client.assert(response.status === 200, "Expected HTTP 200");
#   });
# %}

###

############################################################
# 6) Get Audit Logs (With Filters)
# Endpoint: GET /api/monitoring/audit-logs?activity_type=TAB_SWITCH&limit=5
# Auth: Lecturer token
# Expected: 200 OK
# Expected payload: Only TAB_SWITCH logs, capped at 5 rows
############################################################
GET {{baseUrl}}/api/monitoring/audit-logs?activity_type=TAB_SWITCH&limit=5
Authorization: Bearer {{lecturerToken}}

# > {%
#   client.test("Get Audit Logs (filtered) returns 200", function () {
#     client.assert(response.status === 200, "Expected HTTP 200");
#   });
# %}

###

############################################################
# 7) Mark Alert as Reviewed
# Endpoint: PUT /api/monitoring/alerts/{{alertId}}/review
# Auth: Lecturer token
# Expected: 200 OK with success message
#
# IMPORTANT NOTE:
# - This request depends on step 4 successfully capturing `alertId`.
# - If there were no alerts in step 4, `alertId` remains empty.
# - In that case, this request can fail (typically 404, or 500 depending on
#   route handling/input parsing behavior).
############################################################
PUT {{baseUrl}}/api/monitoring/alerts/{{alertId}}/review
Authorization: Bearer {{lecturerToken}}
Content-Type: application/json

{}

# > {%
