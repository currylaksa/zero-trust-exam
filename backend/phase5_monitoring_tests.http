############################################################
# 1) Login as Lecturer
# Endpoint: POST /api/auth/login
# Credentials: lecturer@utm.my / Password123!
# Expected: 200 OK with response.body.token
# Action: Save token to global variable `lecturerToken`
############################################################
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "lecturer@utm.my",
  "password": "Password123!"
}

# > {%
