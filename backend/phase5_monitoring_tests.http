############################################################
# 2) Login as Student
# Endpoint: POST /api/auth/login
# Credentials: student1@utm.my / Password123!
# Expected: 200 OK with response.body.token
# Action: Save token to global variable `studentToken`
# Note: This token is used later to verify student role is denied.
############################################################
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "student1@utm.my",
  "password": "Password123!"
}

