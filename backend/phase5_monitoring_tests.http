############################################################
# Phase 5.3 Test Suite - Monitoring APIs (Zero-Trust)
# Project: Zero-Trust Based Secure Online Examination System
# Tool: VS Code REST Client Extension
# Backend: http://localhost:5001
#
# HOW TO USE:
# 1) Make sure backend server is running on port 5001.
# 2) Open this file in VS Code.
# 3) Run requests from top to bottom IN ORDER.
# 4) Do not skip login requests because they populate JWT variables.
#
# WHY THIS ORDER MATTERS:
# - Lecturer token is required for all monitoring dashboard endpoints.
# - Student token is required for role-based access denial tests.
# - Alert review endpoint needs alertId captured from the Alerts response.
############################################################

@baseUrl = http://localhost:5001

